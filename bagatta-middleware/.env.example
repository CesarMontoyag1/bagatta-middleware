# ═══════════════════════════════════════════════════════════════════
#  Bagatta Middleware — Variables de entorno
#  Copia este archivo como .env y completa cada valor.
#  NUNCA comitas el .env al repositorio.
# ═══════════════════════════════════════════════════════════════════

# ── Servidor ────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3000"

# ── Base de datos (Supabase) ────────────────────────────────────────
# Ambas URL se obtienen en: Supabase → Settings → Database → Connection string
# DATABASE_URL  → modo "Transaction" (pooler) — para queries normales
# DIRECT_URL    → modo "Session" (directo)    — para migraciones de Prisma
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres"

# ── JWT (RS256) ─────────────────────────────────────────────────────
# Las llaves se codifican en base64 para evitar problemas con saltos
# de línea en el .env en distintos sistemas operativos.
#
# Generar el par de llaves:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Codificar a base64 (una sola línea sin saltos):
#   En Linux/Mac:
#     base64 -w 0 private.pem   → pegar en JWT_PRIVATE_KEY_B64
#     base64 -w 0 public.pem    → pegar en JWT_PUBLIC_KEY_B64
#   En Windows (PowerShell):
#     [Convert]::ToBase64String([IO.File]::ReadAllBytes("private.pem"))
#     [Convert]::ToBase64String([IO.File]::ReadAllBytes("public.pem"))
#
# Borrar los .pem tras copiar: rm private.pem public.pem
JWT_PRIVATE_KEY_B64="LS0tLS1CRUdJTiBSU0EgUFJJVkFURSBLRVktLS0tLQ..."
JWT_PUBLIC_KEY_B64="LS0tLS1CRUdJTiBQVUJMSUMgS0VZLS0tLS0..."
JWT_ACCESS_EXPIRES_IN="8h"

# Secret interno para operaciones sistema → sistema (mínimo 32 caracteres)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYSTEM_INTERNAL_SECRET="genera-uno-con-el-comando-de-arriba-minimo-32-chars"

# ── Shopify ─────────────────────────────────────────────────────────
# Todas las llaves se obtienen en: partners.shopify.com → tu app → Configuración
#
# SHOPIFY_SHOP_DOMAIN  → partners.shopify.com → Stores → tu tienda → dominio
# SHOPIFY_ACCESS_TOKEN → sección "Token de automatización de la app" (atkn_...)
# SHOPIFY_WEBHOOK_SECRET → sección "Credenciales" → campo "Secreto" (shpss_...)
# SHOPIFY_LOCATION_ID  → llamar a /admin/api/2024-04/locations.json con el token
SHOPIFY_SHOP_DOMAIN="tu-tienda.myshopify.com"
SHOPIFY_ACCESS_TOKEN="REEMPLAZA_ESTE_VALOR"
SHOPIFY_WEBHOOK_SECRET="REEMPLAZA_ESTE_VALOR"
SHOPIFY_API_VERSION="2024-04"
SHOPIFY_LOCATION_ID="12345678901"

# ── Alegra ──────────────────────────────────────────────────────────
# ALEGRA_USER_EMAIL → tu email de login en Alegra
# ALEGRA_API_TOKEN  → Alegra → Configuración → API → tu token
#
# Los IDs de categoría y bodega se resuelven AUTOMÁTICAMENTE al arrancar
# el servidor buscando por nombre — no necesitas buscarlos manualmente.
# Solo asegúrate de que los nombres coincidan exactamente con los de Alegra.
ALEGRA_USER_EMAIL="thekiller1525@gmail.com"
***REMOVED***
ALEGRA_SYNC_CATEGORY_NAME="Tienda Virtual y Física"
ALEGRA_WAREHOUSE_NAME="Principal"
ALEGRA_UNIT_OF_MEASURE="Unidad"

# ── Sincronización ──────────────────────────────────────────────────
POLLING_INTERVAL_SECONDS="10"
CATCHUP_THRESHOLD_MINUTES="2"
DOWNTIME_ALERT_THRESHOLD_MINUTES="5"
SELF_PING_INTERVAL_MINUTES="10"

# ── Rate limiting ───────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"
AUTH_RATE_LIMIT_MAX="10"

# ── CORS y URLs ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN="http://localhost:5173"
SELF_URL="http://localhost:3000"

# ── Seed (solo para npm run db:seed) ───────────────────────────────
SEED_ADMIN_EMAIL="admin@bagatta.co"
SEED_ADMIN_PASSWORD="CambiaEstoAntesDeProduccion123!"
